# Dependencies & build output
node_modules/
dist/
.vite/
*.tsbuildinfo
*.log

# Environment — never commit real values (template .env.example IS committed)
.env
.env.*
!.env.example

# Heavy source art — the app bundles optimized copies (src/assets/), so the
# large originals stay local instead of bloating the repo.
assets/menu-hero/*.png
assets/menu-hero/*.jpg
assets/menu-hero/*.jpeg
assets/menu-hero/*.webp
assets/logo/*.png

# Local tooling (machine-specific)
.claude/
.vercel/

.vercel
.gstack/
